# ── OpenAI ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here
LLM_MODEL=gpt-4o

# ── Neo4j (graph store) ────────────────────────────────────────────────────
# docker run -p 7474:7474 -p 7687:7687 -e NEO4J_AUTH=neo4j/password neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j

# ── Qdrant (vector store) ──────────────────────────────────────────────────
# Managed via docker-compose.yml — no manual docker run needed
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=graphrag_elements
# QDRANT_API_KEY=           # only needed for Qdrant Cloud

# ── PostgreSQL (workspace metadata) ───────────────────────────────────────
# Managed via docker-compose.yml
# User: graphrag  |  Password: graphrag  |  DB: graphrag  |  Port: 5432
POSTGRES_URL=postgresql://graphrag:graphrag@localhost:5433/graphrag

# ── Embeddings ─────────────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSION=1024

# ── Quality thresholds ─────────────────────────────────────────────────────
CONFIDENCE_THRESHOLD=0.6
MAX_TOKENS_EXTRACTION=4000
MAX_CHUNK_CHARS=3000
CHUNK_OVERLAP_CHARS=200
